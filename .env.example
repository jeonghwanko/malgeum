# ─────────────────────────────────────────────────────────
# 맑음 (Malgeum) 환경변수 템플릿
# 이 파일을 `.env`로 복사한 후 값을 채워주세요.
# ─────────────────────────────────────────────────────────

# ── 필수 ─────────────────────────────────────────────────

# OpenWeatherMap API 키 (필수)
# https://openweathermap.org/api
EXPO_PUBLIC_WEATHER_API_KEY=

# Firebase (Anonymous Auth + Firestore)
# https://console.firebase.google.com → 프로젝트 설정 → 웹 앱 SDK 설정
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── 앱 식별자 (선택 — 본인 프로젝트에 맞게 변경) ────────────

APP_BUNDLE_ID=gg.pryzm.malgeum
APP_GROUP_ID=group.gg.pryzm.malgeum
APPLE_TEAM_ID=
EAS_PROJECT_ID=

# 네이티브 Firebase 설정 파일 경로 (프로젝트 루트에 위치)
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

# ── 선택 기능 ────────────────────────────────────────────

# Sentry (에러 추적) — DSN 없으면 비활성화
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=malgeum

# RevenueCat (인앱 구독) — 키 없으면 프리미엄 기능 비활성화
EXPO_PUBLIC_REVENUECAT_IOS=
EXPO_PUBLIC_REVENUECAT_ANDROID=

# AdMob (리워드 광고) — 없으면 테스트 ID 사용
ADMOB_APP_ID_ANDROID=
ADMOB_APP_ID_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=

# AI 날씨 도우미 프록시 — 미설정 시 폴백 응답만 반환
EXPO_PUBLIC_AI_PROXY_URL=
EXPO_PUBLIC_MALGEUM_AI_KEY=

# k-skill proxy (미설정 시 공개 엔드포인트 사용)
EXPO_PUBLIC_KSKILL_PROXY_URL=

# 한국관광공사 TourAPI / 고캠핑 (축제·캠핑장) — 공공데이터포털 키
EXPO_PUBLIC_TOUR_API_KEY=

# KOPIS 공연예술통합전산망 — kopis.or.kr 발급
EXPO_PUBLIC_KOPIS_API_KEY=

# findthem 추천 API (서버사이드 스코어링 + 잔소리 connection CRUD)
EXPO_PUBLIC_RECOMMENDATION_API_URL=
EXPO_PUBLIC_RECOMMENDATION_APP_KEY=

# LinkPrice 제휴 템플릿 (수익화 — 선택)
EXPO_PUBLIC_LINKPRICE_CLICK_TEMPLATE=

# ── 브랜딩/URL ───────────────────────────────────────────

# Universal Link / App Link 호스트 (잔소리 초대 웹페이지)
EXPO_PUBLIC_INVITE_HOST=example.com
EXPO_PUBLIC_INVITE_WEB_BASE=https://example.com/n

# 공유 카드 다운로드 페이지 URL
EXPO_PUBLIC_DOWNLOAD_URL=https://example.com/malgeum/download

# 개인정보 처리방침 / 이용약관 페이지
EXPO_PUBLIC_PRIVACY_URL=https://example.com/malgeum/privacy-policy.html
EXPO_PUBLIC_TERMS_URL=https://example.com/malgeum/terms-of-service.html
